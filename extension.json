{
	"name": "AnnotateImage",
	"version": "0.2",
	"author": "[https://www.wikiskripta.eu/w/User:Josmart Josef Martiňák]",
	"url": "https://github.com/wikiskripta/AnnotateImage",
	"descriptionmsg": "annotateimage-desc",
	"license-name": "MIT",
	"type": "editor",
	"status": "stable",
	"requires": {
		"MediaWiki": ">= 1.45.0"
	},
	"MessagesDirs": {
		"AnnotateImage": [
			"i18n"
		]
	},
	"AutoloadClasses": {
		"AnnotateImageHooks": "AnnotateImageHooks.php"
	},
	"ResourceModules": {
		"ext.AnnotateImageEmbed": {
			"position": "bottom",
			"styles": [
				"ext.AnnotateImageEmbed.css"
			],
			"scripts": [
				"jquery.annotate.js",
				"ext.AnnotateImageEmbed.js"
			],
			"messages": ["annotateimage-info"]
		},
		"ext.AnnotateImageEdit": {
			"position": "bottom",
			"styles": [
				"ext.AnnotateImageEdit.css"
			],
			"scripts": [
				"jquery.annotate.js",
				"ext.AnnotateImageEdit.js"
			],
			"messages": [
				"annotateimage-info",
				"annotateimage-add",
				"annotateimage-delete",
				"annotateimage-save",
				"annotateimage-edit",
				"annotateimage-delete",
				"annotateimage-cancel",
				"annotateimage-text",
				"annotateimage-success",
				"annotateimage-error",
				"annotateimage-updated"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "AnnotateImage/resources"
	},
	"Hooks": {
		"BeforePageDisplay": "AnnotateImageHooks::fireAnnotator"
	},
	"config": {
		"AllowedExtensions": {
			"value": "jpg|png|svgjpg|png|svg|JPG|PNG|SVG",
			"description": "File extensions available for use with an annotator."
		},
		"MinWidth": {
			"value": 250,
			"description": "Min width of an annotable image."
		}
	},
	"ConfigRegistry": {
		"AnnotateImage": "GlobalVarConfig::newInstance"
	},
	"manifest_version": 2
}
